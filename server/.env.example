# Copy to the REPO ROOT as `.env`  (config.py loads <repo-root>/.env)
#   cp server/.env.example .env

# ---- Supabase (Personal project, schema = assemblyai) ----
SUPABASE_URL=https://njuczhydpfzzsgvvvpvo.supabase.co
# Dashboard -> Project Settings -> API -> Project API keys -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=assemblyai

# ---- AssemblyAI ----
ASSEMBLYAI_API_KEY=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-opus-4-8

# ---- Twilio ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio voice number you bought, E.164 e.g. +14155551234
TWILIO_PHONE_NUMBER=

# ---- Public host for Twilio webhooks (your ngrok host, bare or full URL) ----
# e.g. ab12cd34.ngrok-free.app   (the scripted app prepends https://)
PUBLIC_HOST=

# ---- Agent persona (optional) ----
COMPANY_NAME=Omnivision Warehousing
PORT=8000
