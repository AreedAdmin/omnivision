# ── Omnivision server environment ──────────────────────────────────
# Copy to .env at the repo root and fill in. Never commit .env.

# AssemblyAI (STT — streaming must be enabled on your account)
ASSEMBLYAI_API_KEY=

# Anthropic (agent brain)
ANTHROPIC_API_KEY=
# Models (defaults are correct; override only if needed)
LIVE_MODEL=claude-sonnet-4-6
EXTRACTION_MODEL=claude-opus-4-8

# Supplier-call mode: "local" (default — simulated call in the browser, no
# Twilio needed) or "twilio" (real outbound phone calls; needs everything below)
CALL_MODE=local

# Twilio (ONLY for CALL_MODE=twilio — leave blank in local mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=          # the number you bought, E.164 e.g. +15551234567
SUPPLIER_DEMO_PHONE=          # teammate's phone, E.164 (also update suppliers table)

# Cartesia (TTS voice)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=            # pick one at play.cartesia.ai

# Supabase
SUPABASE_URL=                 # https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # server-side only, never expose to the dashboard
SUPABASE_PUBLISHABLE_KEY=     # anon/publishable key (dashboard + server fallback)
SUPABASE_SCHEMA=assemblyai    # Postgres schema holding Omnivision tables

# Public host for Twilio Media Streams (ngrok domain, NO protocol prefix)
PUBLIC_HOST=                  # e.g. abc123.ngrok-free.app

# What the agent says on supplier calls
COMPANY_NAME=Omnivision Warehousing
CALLBACK_NUMBER=              # human callback number the agent offers if asked

# Server
PORT=8000
